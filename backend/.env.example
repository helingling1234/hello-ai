# Optional: NCBI API key - raises rate limit from 3 to 10 req/sec
# Get one free at: https://www.ncbi.nlm.nih.gov/account/
NCBI_API_KEY=

# TransVar reference genome version
TRANSVAR_REFVERSION=hg38

# Allowed CORS origins for the frontend
BACKEND_CORS_ORIGINS=["http://localhost:3000"]

# Cache TTLs in seconds
CACHE_TTL_ANNOTATION=3600
CACHE_TTL_LITERATURE=86400
CACHE_TTL_DISEASE=86400
